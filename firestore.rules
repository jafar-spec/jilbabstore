rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin(); 
    }

    // Products & Sections (Catalog) — Public read, admin write
    // Stock deduction is allowed during checkout (only variants field)
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['variants']));    
    }
    match /sections/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /store_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo Codes — Public read for checkout validation, admin write
    match /promocodes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer Profiles — Own data or admin
    match /customers/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders — Strict access control
    match /orders/{orderId} {
      // Allow order creation with basic validation
      allow create: if request.resource.data.keys().hasAll(['items', 'total'])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.total is number;

      // Admin can read all. Customers can only read their own orders.
      allow read: if isAdmin()
                  || (request.auth != null && resource.data.uid == request.auth.uid);

      // Only admin can update/delete
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews — Public read + create, admin manage
    match /reviews/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Newsletter & Support Tickets — Public create, admin manage
    match /newsletter_subscribers/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /support_tickets/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
