rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection
    // Only admins can read. No one can write from client (requires Firebase Admin SDK).
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin(); 
    }

    // Products & Sections (Catalog)
    // Anyone can read. Only admins can write.
    match /products/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sections/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /store_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /promocodes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    // Anyone can create an order. Only admins can read all, update, or delete.
    // Customers can read their own orders if they are logged in.
    match /orders/{document=**} {
      allow create: if true;
      allow read: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews
    // Anyone can read and create. Only admins can update or delete.
    match /reviews/{document=**} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Newsletter & Support Tickets
    // Anyone can create. Only admins can read, update, delete.
    match /newsletter_subscribers/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /support_tickets/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
